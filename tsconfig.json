{
  "compilerOptions": {
    "sourceMap": true,
    "outDir": "build",
    "rootDir": "./",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "es2017",
    "lib": ["es2017"],
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "module": "NodeNext",
    "skipLibCheck": true
  }
}